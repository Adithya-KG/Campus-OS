{
  "name": "CampusOS",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "An AI-native campus operating system that connects every university service into a single intelligent assistant using the Model Context Protocol. One query, multiple coordinated actions.",
  "scripts": {
    "dev": "nitrostack-cli dev",
    "build": "nitrostack-cli build",
    "start": "npm run build && nitrostack-cli start",
    "start:prod": "nitrostack-cli start",
    "upgrade": "nitrostack-cli upgrade",
    "install:all": "nitrostack-cli install",
    "widget": "npm --prefix src/widgets"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": ">=0.1.0",
    "@nitrostack/core": "^1.0.13",
    "@supabase/supabase-js": "^2.110.7",
    "axios": "^1.7.9",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nitrostack/cli": "^1.0.14",
    "@types/node": "^22.10.0",
    "typescript": "^5.3.3"
  },
  "author": "Adithya Gopan",
  "nitrostack": {
    "skillsVersion": "1.0.0"
  }
}
